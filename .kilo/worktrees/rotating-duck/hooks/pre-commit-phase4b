#!/bin/bash

# Phase 4B: Repository Authority Pre-commit Hook
# Prevents governance violations before commit

set -e

echo "🛡️ Phase 4B Governance Pre-commit Check..."

# Colors for output
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
NC='\033[0m' # No Color

VIOLATIONS_FOUND=0

# Get staged PHP files in CRM domain
STAGED_FILES=$(git diff --cached --name-only --diff-filter=ACM | grep -E "app/Services/CRM/.*\.php$" || true)

if [ -z "$STAGED_FILES" ]; then
    echo "✅ No CRM service files staged, skipping Phase 4B checks"
    exit 0
fi

echo "📁 Checking staged CRM files..."

# Check 1: Direct Model Access in Services
echo ""
echo "🔍 Check 1: Direct Model Access Detection..."
for file in $STAGED_FILES; do
    # Check for direct model access patterns
    violations=$(grep -n "Lead::\|Kisi::\|Gorev::\|KisiEtkilesim::" "$file" | \
                 grep -v "use " | \
                 grep -v "namespace " | \
                 grep -v "@var" | \
                 grep -v "@param" | \
                 grep -v "@return" | \
                 grep -v "class " || true)

    if [ ! -z "$violations" ]; then
        echo -e "${RED}❌ VIOLATION: Direct model access in $file${NC}"
        echo "$violations"
        echo ""
        echo -e "${YELLOW}REQUIRED: Use Repository pattern instead${NC}"
        echo "Example: \$this->leadRepository->findById(\$id)"
        echo ""
        VIOLATIONS_FOUND=1
    fi
done

if [ $VIOLATIONS_FOUND -eq 0 ]; then
    echo -e "${GREEN}✅ No direct model access violations${NC}"
fi

# Check 2: Tenantless Cache Keys
echo ""
echo "🔍 Check 2: Tenantless Cache Key Detection..."
CACHE_VIOLATIONS_FOUND=0

for file in $STAGED_FILES; do
    # Check for cache operations without tenant scope
    violations=$(grep -n "Cache::remember\|Cache::rememberForever\|Cache::put\|cache(" "$file" | \
                 grep -v "tenant:" | \
                 grep -v "global_avg_views" | \
                 grep -v "il_list" | \
                 grep -v "ulke_list" | \
                 grep -v "talep_kategori_list" || true)

    if [ ! -z "$violations" ]; then
        echo -e "${RED}❌ VIOLATION: Tenantless cache key in $file${NC}"
        echo "$violations"
        echo ""
        echo -e "${YELLOW}REQUIRED: Use tenant-scoped cache keys${NC}"
        echo "Example: Cache::remember('tenant:{\$tenantId}:crm:stats', ...)"
        echo ""
        echo "Allowlisted public corpus caches:"
        echo "  - global_avg_views"
        echo "  - il_list"
        echo "  - ulke_list"
        echo "  - talep_kategori_list"
        echo ""
        CACHE_VIOLATIONS_FOUND=1
        VIOLATIONS_FOUND=1
    fi
done

if [ $CACHE_VIOLATIONS_FOUND -eq 0 ]; then
    echo -e "${GREEN}✅ No tenantless cache key violations${NC}"
fi

# Check 3: Unscoped Aggregations
echo ""
echo "🔍 Check 3: Unscoped Aggregation Detection..."
AGGREGATION_VIOLATIONS_FOUND=0

for file in $STAGED_FILES; do
    # Check for unscoped aggregations
    violations=$(grep -n "::count()\|::avg(\|::sum(\|::max(\|::min(" "$file" | \
                 grep -v "Repository" || true)

    if [ ! -z "$violations" ]; then
        echo -e "${RED}❌ VIOLATION: Unscoped aggregation in $file${NC}"
        echo "$violations"
        echo ""
        echo -e "${YELLOW}REQUIRED: Use Repository methods with tenant scope${NC}"
        echo "Example: \$this->kisiRepository->getStats(auth()->user())"
        echo ""
        AGGREGATION_VIOLATIONS_FOUND=1
        VIOLATIONS_FOUND=1
    fi
done

if [ $AGGREGATION_VIOLATIONS_FOUND -eq 0 ]; then
    echo -e "${GREEN}✅ No unscoped aggregation violations${NC}"
fi

# Check 4: Queue Job Payload Validation
echo ""
echo "🔍 Check 4: Queue Job Payload Validation..."
QUEUE_VIOLATIONS_FOUND=0

STAGED_JOBS=$(git diff --cached --name-only --diff-filter=ACM | grep -E "app/Jobs/.*\.php$" || true)

for file in $STAGED_JOBS; do
    # Check if job has tenant_id or user_id in constructor
    if grep -q "ShouldQueue" "$file"; then
        if ! grep -q "tenant_id\|user_id" "$file"; then
            echo -e "${RED}❌ VIOLATION: Queue job missing tenant context in $file${NC}"
            echo ""
            echo -e "${YELLOW}REQUIRED: Queue jobs MUST include tenant_id or user_id${NC}"
            echo "Example:"
            echo "  public function __construct("
            echo "      public int \$tenantId,"
            echo "      public int \$userId,"
            echo "      public int \$leadId"
            echo "  ) {}"
            echo ""
            QUEUE_VIOLATIONS_FOUND=1
            VIOLATIONS_FOUND=1
        fi
    fi
done

if [ $QUEUE_VIOLATIONS_FOUND -eq 0 ]; then
    echo -e "${GREEN}✅ No queue job payload violations${NC}"
fi

# Final verdict
echo ""
echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"

if [ $VIOLATIONS_FOUND -eq 1 ]; then
    echo -e "${RED}❌ COMMIT BLOCKED: Phase 4B governance violations detected${NC}"
    echo ""
    echo "Fix the violations above and try again."
    echo ""
    echo "Need help? See:"
    echo "  - docs/governance/PHASE4B_SERVICE_GOVERNANCE_ALIGNMENT.md"
    echo "  - docs/governance/PHASE4B3_VALIDATION_REPORT.md"
    echo ""
    echo "To bypass this check (NOT RECOMMENDED):"
    echo "  git commit --no-verify"
    echo ""
    exit 1
else
    echo -e "${GREEN}✅ Phase 4B Governance: ALL CHECKS PASSED${NC}"
    echo ""
    echo "Commit allowed. Repository Authority pattern enforced."
    echo ""
    exit 0
fi
