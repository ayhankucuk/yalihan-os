# 🏗️ YALIHAN EMLAK - MASTER ENV EXAMPLE (.env.example.master)
# Context7 Standard: C7-ENV-MASTER-2026-01-12
# Durum: ✅ Mühürlendi (Sealed)

# ==============================================================================
# 🌟 1. TEMEL UYGULAMA AYARLARI (CRITICAL)
# ==============================================================================
APP_NAME="Yalıhan Emlak AI"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost
APP_LOCALE=tr
APP_FALLBACK_LOCALE=tr
APP_FAKER_LOCALE=tr_TR

# Playwright E2E Tests
# PLAYWRIGHT_BASE_URL is the PRIMARY authority for browser tests.
# APP_URL is used only as legacy fallback for backward compatibility.
#
# Local dev: http://127.0.0.1:8000
# CI/Staging: set via environment variable
PLAYWRIGHT_BASE_URL=http://127.0.0.1:8000

# ==============================================================================
# 💾 2. VERİTABANI & CACHE (CRITICAL)
# ==============================================================================
DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=yalihanai_v2_production
DB_USERNAME=root
DB_PASSWORD=

# Market İstihbarat Veritabanı (Sahibinden/Hepsiemlak Data)
MARKET_DB_URL=
MARKET_DB_HOST=127.0.0.1
MARKET_DB_PORT=3306
MARKET_DB_DATABASE=yalihan_market
MARKET_DB_USERNAME=root
MARKET_DB_PASSWORD=

# Redis & Cache
REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379
CACHE_STORE=redis
SESSION_DRIVER=redis
QUEUE_CONNECTION=redis

# ==============================================================================
# 🤖 3. AI SERVİSLERİ & CORTEX CPU (CRITICAL)
# ==============================================================================
# Ana sağlayıcı: ollama | openai | anthropic | gemini
AI_PROVIDER=ollama
AI_DEFAULT_MODEL=gemma2:2b
AI_FALLBACK_MODEL=gpt-3.5-turbo
AI_REQUIRE_TLS=false # KVKK Uyumu için production'da true olmalı

# OpenAI Settings
OPENAI_API_KEY=

# Anthropic (Claude) Settings
ANTHROPIC_API_KEY=

# Google AI (Gemini) Settings
GOOGLE_API_KEY=
GOOGLE_MODEL=gemini-2.5-flash

# DeepSeek & Minimax (Opsiyonel alternatifler)
DEEPSEEK_API_KEY=
MINIMAX_API_KEY=
MINIMAX_MODEL=minimax-m2

# Local AI (Ollama) - SSH/VPN üzerinden bağlanır
OLLAMA_API_URL=https://ollama.yalihanemlak.internal
OLLAMA_MODEL=gemma2:2b

# AI Budget Kill Switch (default: true — hard cap aktif)
AI_HARD_CAP_ENABLED=true

# UPS AI Akıllı Filtreleme
UPS_AI_SMART_CONTEXT=false
UPS_AI_SMART_CONTEXT_TOP_N=15
UPS_AI_SMART_CONTEXT_MAX=25

# ==============================================================================
# 📱 4. WHATSAPP & İLETİŞİM SERVİSLERİ (CRITICAL)
# ==============================================================================
# Meta Platform (shared App Secret for Facebook, Instagram, WhatsApp webhooks)
META_APP_SECRET=

# WhatsApp Business API (Meta)
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_BUSINESS_ACCOUNT_ID=
WHATSAPP_WEBHOOK_VERIFY_TOKEN=
WHATSAPP_API_VERSION=v18.0

# Instagram Business API (Meta)
INSTAGRAM_ACCESS_TOKEN=
INSTAGRAM_ACCOUNT_ID=
INSTAGRAM_BUSINESS_ACCOUNT_ID=
INSTAGRAM_WEBHOOK_VERIFY_TOKEN=
INSTAGRAM_API_VERSION=v18.0

# Facebook Messenger (Meta)
FACEBOOK_PAGE_ACCESS_TOKEN=
FACEBOOK_WEBHOOK_VERIFY_TOKEN=
FACEBOOK_API_VERSION=v18.0

# Telegram Bot (YalihanCortex_Bot)
TELEGRAM_BOT_TOKEN=
TELEGRAM_BOT_USERNAME=YalihanCortex_Bot
TELEGRAM_WEBHOOK_URL=
TELEGRAM_WEBHOOK_SECRET=
TELEGRAM_TEAM_CHANNEL_ID=
TELEGRAM_ADMIN_CHAT_ID=

# SMS Sağlayıcıları (netgsm | iletimerkezi)
SMS_PROVIDER=netgsm
NETGSM_USERNAME=
NETGSM_PASSWORD=
ILETIMERKEZI_API_KEY=
ILETIMERKEZI_API_HASH=

# ==============================================================================
# �🗺️ 5. HARİTA, LOKASYON & TAPU (CRITICAL)
# ==============================================================================
# Harita Görüntüleme & Geocoding
GOOGLE_MAPS_API_KEY=
GOOGLE_MAPS_REGION=tr
GOOGLE_MAPS_LANGUAGE=tr

# TKGM (Tapu Kadastro Genel Müdürlüğü) Parsel Sorgu
TKGM_BASE_URL=https://parselsorgu.tkgm.gov.tr
TKGM_API_KEY=
TKGM_CACHE_ENABLED=true

# Diğer Coğrafi Servisler (Opsiyonel)
WIKIMAPIA_API_KEY=
NOMINATIM_BASE_URL=https://nominatim.openstreetmap.org

# ==============================================================================
# 💳 6. ÖDEME SİSTEMLERİ & FİNANS (CRITICAL/OPTIONAL)
# ==============================================================================
# Not: Mevcut kodda ROI ve Komisyon hesaplamaları dahili yapılmaktadır.
# Aşağıdaki alanlar gelecekteki Iyzico/Stripe entegrasyonu için ayrılmıştır.
IYZICO_API_KEY=
IYZICO_SECRET_KEY=
IYZICO_BASE_URL=https://sandbox-api.iyzipay.com

PAYMENT_CURRENCY=TRY
DB_ENCRYPT=yes # Finansal veriler için DB encryption durumu

# ==============================================================================
# 🔄 7. OTOMASYON & n8n (OPTIONAL)
# ==============================================================================
N8N_ENABLED=true
N8N_WEBHOOK_URL=http://localhost:5678
N8N_WEBHOOK_SECRET=
N8N_WEBHOOK_TOKEN=
N8N_NEW_ILAN_WEBHOOK=

# ==============================================================================
# 🏢 8. YALIHAN KURUMSAL BİLGİLER (OPTIONAL)
# ==============================================================================
COMPANY_NAME="Yalıhan Emlak"
COMPANY_EMAIL=info@yalihanemlak.com.tr
COMPANY_PHONE=
COMPANY_ADDRESS=

# ==============================================================================
# 🛠️ 9. OPSİYONEL / TEKNİK AYARLAR
# ==============================================================================
LOG_CHANNEL=daily
LOG_LEVEL=debug
TELESCOPE_ENABLED=true
HORIZON_NAME=yalihan-horizon

# ==============================================================================
# 📊 10. TELEMETRY & OBSERVABILITY (L5 - SELF-PROTECTING SYSTEM)
# ==============================================================================
# Performance Budgets (CI Regression Gate)
PERF_WIZARD_CONTEXT_P95_MS=400  # Wizard context API p95 threshold
PERF_AI_GENERATION_P95_MS=3000  # AI title generation p95 threshold
PERF_DASHBOARD_LOAD_P95_MS=1500 # Dashboard load p95 threshold
PERF_ERROR_RATE_THRESHOLD=0.02  # Maximum acceptable error rate (2%)

# Telemetry Anomaly Detection (Runtime)
TELEMETRY_ANOMALY_DETECTION_ENABLED=true
TELEMETRY_ANOMALY_ALERT_CHANNELS=slack,log  # slack,email,log

# Alert Channels
SLACK_WEBHOOK_URL=  # Slack webhook for performance & anomaly alerts
ALERT_EMAIL=alerts@yalihanemlak.com.tr  # Email for critical anomalies

# AI Cost Budget (Daily Limits)
AI_DAILY_BUDGET_USD=50  # Maximum daily AI cost in USD
AI_TOKEN_LIMIT_PER_REQUEST=4000  # Token limit per single request
AI_COST_ALERT_THRESHOLD=0.80  # Alert when 80% of budget consumed
AI_FALLBACK_PROVIDER=openai-gpt-3.5-turbo  # Cheaper model for budget overflow

# Telemetry Retention (Days)
TELEMETRY_LOG_RETENTION_DAYS=30
TELEMETRY_SECURITY_LOG_RETENTION_DAYS=90
TELEMETRY_BEKCI_LOG_RETENTION_DAYS=90

# ==============================================================================
# 🧩 11. EKSTRA SERVİS AYARLARI (SYNC)
# ==============================================================================
# AWS (S3/SES)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1

# Azure Speech
AZURE_SPEECH_API_KEY=
AZURE_SPEECH_REGION=westeurope

# Google Cloud Extra
GOOGLE_MAPS_TIMEOUT=30
GOOGLE_SPEECH_API_KEY=

# ElevenLabs (Voice AI)
ELEVENLABS_API_KEY=
ELEVENLABS_BASE_URL=https://api.elevenlabs.io
ELEVENLABS_MODEL=eleven_multilingual_v2
ELEVENLABS_TIMEOUT=30

# Nominatim (OSM)
NOMINATIM_CACHE_ENABLED=true
NOMINATIM_CACHE_TTL=86400
NOMINATIM_EMAIL=
NOMINATIM_TIMEOUT=15

# Wikimapia
WIKIMAPIA_BASE_URL=http://api.wikimapia.org
WIKIMAPIA_CACHE_ENABLED=true
WIKIMAPIA_CACHE_TTL=86400
WIKIMAPIA_FORMAT=json
WIKIMAPIA_LANGUAGE=tr
WIKIMAPIA_TIMEOUT=15

# Mailgun/Postmark
MAIL_FROM_ADDRESS=
MAILGUN_DOMAIN=
MAILGUN_SECRET=
MAILGUN_ENDPOINT=
POSTMARK_TOKEN=

# n8n Hooks (Workflow Automation)
N8N_TIMEOUT=30
N8N_GOREV_CREATED_WEBHOOK=
N8N_GOREV_DEADLINE_YAKLASIYOR_WEBHOOK=
N8N_GOREV_GECIKTI_WEBHOOK=
N8N_GOREV_DURUM_CHANGED_WEBHOOK=
N8N_ILAN_PRICE_CHANGED_WEBHOOK=
N8N_NEW_ILAN_WEBHOOK=
N8N_WEBHOOK_URL=http://localhost:5678
N8N_WEBHOOK_SECRET=

# Frontend API Security
FRONTEND_API_KEY=
FRONTEND_API_ALLOWED_IPS=
FRONTEND_API_LOG_REQUESTS=false
FRONTEND_API_RATE_LIMIT=60

# ==============================================================================
# 🤖 OPENCLAW AGENT GATEWAY
# ==============================================================================
OPENCLAW_ENABLED=false
OPENCLAW_AGENT_TOKEN=
OPENCLAW_PROPOSAL_ONLY=true
OPENCLAW_RPM=30
OPENCLAW_RPH=500

