{
  "name": "yalihanemlakwarp-mcp-server",
  "version": "1.0.0",
  "description": "MCP Server for YaliHaneMlakWarp TestSprite integration",
  "type": "module",
  "main": "mcp-servers/yalihan-bekci-mcp.js",
  "scripts": {
    "start": "node mcp-servers/yalihan-bekci-mcp.js",
    "dev": "vite",
    "mcp:context7": "CONTEXT7_API_KEY=${CONTEXT7_API_KEY} npx -y @upstash/context7-mcp --transport stdio",
    "mcp:bekci": "node mcp-servers/yalihan-bekci-mcp.js",
    "mcp:dev": "node --watch mcp-servers/yalihan-bekci-mcp.js",
    "build": "vite build",
    "test": "vitest run --environment jsdom",
    "usta": "node scripts/tools/usta-test.mjs",
    "usta:web-dev": "node scripts/tools/usta-web-developer.mjs",
    "usta:ai": "node scripts/tools/usta-ai-kesfedici.mjs",
    "usta:full": "npm run usta:ai && npm run usta:web-dev",
    "usta:report": "cat usta-web-developer-raporu.md | head -100",
    "setup": "npm install && npx husky install && chmod +x .husky/* && echo '✅ Setup tamamlandı! Enforcement için: npm run dap:autopilot'",
    "fix": "npm run lint:fix && npm run format && php artisan standard:check --fix",
    "lint": "npm run lint:js && npm run lint:php",
    "lint:js": "eslint resources/js --ext .js --max-warnings 0",
    "lint:php": "./vendor/bin/php-cs-fixer fix --dry-run --diff",
    "lint:fix": "eslint resources/js --ext .js --fix && ./vendor/bin/php-cs-fixer fix",
    "format": "prettier --write \"resources/**/*.{js,css,blade.php,vue}\"",
    "check": "npm run lint && php artisan standard:check && npm run governance:check",
    "scan:jquery": "node scripts/tools/scan-jquery.js",
    "prepare": "node scripts/tools/install-hooks.cjs",
    "check:darkmode": "node scripts/tools/fix-dark-mode.cjs --dry",
    "fix:darkmode": "node scripts/tools/fix-dark-mode.cjs --apply",
    "harden:darkmode": "node scripts/tools/fix-dark-mode.cjs --apply && npm run check",
    "ci:darkmode": "node scripts/guards/ci-guard-dark-mode.cjs",
    "authority:compile": "node scripts/tools/compile-authority.cjs",
    "decision:compile": "node scripts/tools/compile-decision-table.cjs",
    "contract:compile": "node scripts/tools/compile-api-contract.cjs",
    "dap:detect": "node scripts/tools/dap-decision-engine.cjs",
    "dap:drift": "npm run authority:compile && npm run decision:compile && npm run contract:compile && npm run seeder:verify && node ./scripts/tools/dap-drift-check.cjs && npm run governance:verify",
    "docs:governance:check": "node ./scripts/tools/dap-docs-governance.cjs",
    "docs:governance:apply": "node ./scripts/tools/dap-docs-governance.cjs --apply",
    "dap:docs": "node ./scripts/tools/dap-map-check.cjs && npm run docs:governance:check",
    "dap:bekci:prune": "node ./scripts/tools/bekci-prune.cjs",
    "dap:precheck:retention": "node ./scripts/tools/precheck-retention.cjs",
    "dap:verify": "./scripts/guards/quality-gate.sh",
    "dap:seal": "node ./scripts/tools/dap-seal.cjs",
    "security:audit": "node scripts/guards/security-audit-wrapper.cjs",
    "security:baseline:update": "node scripts/tools/security-baseline-update.cjs",
    "governance:manifest": "node scripts/tools/generate-core-manifest.cjs",
    "governance:verify": "node scripts/guards/core-integrity-check.cjs",
    "governance:check": "node scripts/guards/governance-check.cjs",
    "wizard:guard": "node scripts/guards/wizard-cascade-guard.cjs",
    "dap:autopilot": "npm run dap:detect && npm run dap:bekci:prune && npm run dap:precheck:retention && npm run dap:seal",
    "dap:legacy": "node scripts/guards/legacy-guard.cjs",
    "e2e": "npx playwright test",
    "test:browser": "npm run e2e",
    "e2e:ui": "npx playwright test --headed",
    "e2e:report": "npx playwright show-report",
    "e2e:trace": "npx playwright show-trace",
    "e2e:precheck": "npx playwright test tests/e2e/precheck.property-type-manager.spec.ts",
    "e2e:wizard-env": "node scripts/tools/generate-wizard-env.js",
    "e2e:verify-paths": "node scripts/tools/verify-precheck-paths.js",
    "e2e:ci-guard": "node scripts/guards/ci-guard-wizard.js",
    "e2e:auto-heal:dry": "node scripts/tools/auto-heal-wizard.js --mode=dry",
    "e2e:auto-heal:apply:staging": "node scripts/tools/auto-heal-wizard.js --mode=apply --env=staging",
    "e2e:wizard:normalize:dry": "npm run e2e:wizard-env && node scripts/tools/normalize-all-junctions.js && npm run e2e:ci-guard",
    "e2e:wizard:normalize:staging": "npm run e2e:wizard-env && node scripts/tools/normalize-all-junctions.js --mode=apply --env=staging && npm run e2e:ci-guard",
    "e2e:wizard:smart": "npm run e2e:wizard-env && npm run e2e:auto-heal:dry && npm run e2e:ci-guard",
    "e2e:wizard:staging-heal": "npm run e2e:wizard-env && npm run e2e:auto-heal:apply:staging && npm run e2e:ci-guard",
    "e2e:arsa": "npm run e2e:wizard:smart && npx playwright test tests/e2e/arsa-wizard.spec.ts --headed",
    "e2e:arsa:ui": "npm run e2e:wizard:smart && npx playwright test tests/e2e/arsa-wizard.spec.ts --ui",
    "seeder:verify": "node scripts/guards/seeder-gate.cjs",
    "seeder:baseline": "node scripts/guards/seeder-gate.cjs --baseline",
    "sab:check": "php artisan sab:integrity-scan && php artisan guard:actions:v10_9 && php artisan quality:gate",
    "sab:gate": "./scripts/guards/quality-gate.sh"
  },
  "dependencies": {
    "@alpinejs/collapse": "^3.15.0",
    "@modelcontextprotocol/sdk": "^0.5.0",
    "alpinejs": "^3.15.0",
    "apexcharts": "^5.3.6",
    "body-parser": "^2.2.0",
    "esbuild": "^0.25.10",
    "express": "^5.1.0",
    "laravel-vite-plugin": "^2.0.1",
    "leaflet": "^1.9.4",
    "leaflet-draw": "^1.0.4",
    "rollup": "^4.52.4"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "keywords": [
    "mcp",
    "testsprite",
    "yalihanemlakwarp",
    "testing"
  ],
  "author": "YaliHaneMlakWarp Team",
  "license": "MIT",
  "devDependencies": {
    "@eslint/js": "^9.0.0",
    "@playwright/test": "^1.58.1",
    "@testing-library/dom": "^9.3.3",
    "@types/node": "^25.1.0",
    "autoprefixer": "^10.4.21",
    "baseline-browser-mapping": "^2.9.19",
    "dotenv": "^17.2.4",
    "eslint": "^9.38.0",
    "husky": "^9.1.7",
    "jsdom": "^27.2.0",
    "lint-staged": "^15.5.2",
    "playwright": "^1.58.0",
    "postcss": "^8.5.6",
    "prettier": "^3.6.2",
    "puppeteer": "^24.34.0",
    "tailwindcss": "^3.4.18",
    "terser": "^5.44.0",
    "vitest": "^1.6.0"
  },
  "lint-staged": {
    "resources/**/*.js": [
      "prettier --write"
    ],
    "resources/**/*.css": [
      "prettier --write"
    ]
  }
}
