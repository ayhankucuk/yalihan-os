#!/usr/bin/env bash

# ═══════════════════════════════════════════════════════════════════════════
# 🛡️ Yalıhan Bekçi: Pre-Commit Hook
# ═══════════════════════════════════════════════════════════════════════════
#
# Fast architectural check before each commit.
# Runs SAB integrity scan (NEW violations only) + model drift scan.
# Full quality gate runs on pre-push.
#
# Installation:
#   bash hooks/install.sh
#
# Bypass (emergency only):
#   git commit --no-verify
# ═══════════════════════════════════════════════════════════════════════════

set -euo pipefail

echo ""
echo "🛡️ Yalıhan Bekçi: Pre-Commit Architectural Guard"
echo "════════════════════════════════════════════════════"
echo ""

FAILED=0

# Step 1: SAB Integrity Scan (NEW violations check)
echo "🔍 [1/3] SAB Integrity Scan..."
if php artisan sab:integrity-scan 2>&1 | grep -q "No NEW architectural violations"; then
    echo "   ✅ SAB: No NEW violations"
else
    echo "   ❌ SAB: NEW architectural violations detected!"
    FAILED=1
fi

# Step 2: Model Drift Scan
echo "🔍 [2/3] Model Drift Scan..."
if php artisan model:drift-scan 2>&1 | grep -q "No ghost fields detected"; then
    echo "   ✅ Drift: No ghost fields"
else
    echo "   ⚠️  Drift: Ghost fields or missing tables detected (non-blocking)"
fi

# Step 3: Route Guard
echo "🔍 [3/3] Route Guard..."
if php artisan guard:routes:v2 2>&1 | grep -q "PASSED"; then
    echo "   ✅ Routes: Guard passed"
else
    echo "   ❌ Routes: Guard FAILED!"
    FAILED=1
fi

echo ""

if [ "$FAILED" -ne 0 ]; then
    echo "════════════════════════════════════════════════════"
    echo "❌ PRE-COMMIT CHECK FAILED — COMMIT BLOCKED"
    echo "════════════════════════════════════════════════════"
    echo ""
    echo "📝 Fix the violations above and try again."
    echo ""
    echo "⚠️  To bypass (EMERGENCY ONLY):"
    echo "   git commit --no-verify"
    echo ""
    exit 1
fi

echo "════════════════════════════════════════════════════"
echo "✅ Pre-Commit Check PASSED — Proceeding with commit"
echo "════════════════════════════════════════════════════"
echo ""
exit 0
