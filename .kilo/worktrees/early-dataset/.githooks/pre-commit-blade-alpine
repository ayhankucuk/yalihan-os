#!/bin/bash
# Pre-commit Hook: Blade @include + Alpine.js Scope Validation
# Bu hook, Blade @include içinde Alpine.js scope erişimlerinde $parent prefix eksikliğini tespit eder.

set -e

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
PROJECT_ROOT="$(dirname "$SCRIPT_DIR")"

# Renkler
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
NC='\033[0m' # No Color

ERRORS_FOUND=0

# Test dosyaları hariç Blade dosyalarını bul
BLADE_FILES=$(git diff --cached --name-only --diff-filter=ACM | grep -E '\.blade\.php$' || true)

if [ -z "$BLADE_FILES" ]; then
    echo -e "${GREEN}✓${NC} Blade dosyası bulunamadı, kontrol atlandı."
    exit 0
fi

echo -e "${YELLOW}🔍 Blade @include + Alpine.js Scope Validation${NC}"
echo "Kontrol edilen dosyalar: $(echo "$BLADE_FILES" | wc -l)"

for FILE in $BLADE_FILES; do
    # Dosya içeriğini staging area'dan al (committed versiyonu)
    CONTENT=$(git show ":$FILE" 2>/dev/null || cat "$PROJECT_ROOT/$FILE")
    
    # @include kullanan satırları bul
    if ! echo "$CONTENT" | grep -q "@include"; then
        continue
    fi
    
    # @include bloğu içindeki Alpine.js directives'i kontrol et
    # Regex: @include ile başla, } ile bitir arasında x-show/x-if/x-if var mı?
    
    # Satır satır kontrol
    IN_INCLUDE=0
    LINE_NUM=0
    while IFS= read -r line; do
        ((LINE_NUM++))
        
        # @include başlatıyor mu?
        if echo "$line" | grep -q "@include"; then
            IN_INCLUDE=1
        fi
        
        # x-show veya x-if içeriyor mu ve $parent yok mu?
        if [ $IN_INCLUDE -eq 1 ]; then
            if echo "$line" | grep -qE 'x-(show|if|bind)'; then
                if ! echo "$line" | grep -q '\$parent'; then
                    echo -e "${RED}✗ HATA${NC} ($FILE:$LINE_NUM):"
                    echo "  $line"
                    echo -e "  ${YELLOW}→ Çözüm: \$parent prefix ekle${NC}"
                    ERRORS_FOUND=$((ERRORS_FOUND + 1))
                fi
            fi
            
            # Include bloğu kapandı mı?
            if echo "$line" | grep -qE '(^|[^{])}\s*$' && ! echo "$line" | grep -q "@include"; then
                IN_INCLUDE=0
            fi
        fi
    done <<< "$CONTENT"
done

if [ $ERRORS_FOUND -gt 0 ]; then
    echo ""
    echo -e "${RED}❌ $ERRORS_FOUND hata bulundu!${NC}"
    echo -e "${YELLOW}Çözüm: Blade @include içinde Alpine.js directives'de \$parent prefix kullanın${NC}"
    echo ""
    echo -e "${YELLOW}Örnek DOĞRU KUL. (arsa-fields.blade.php):${NC}"
    echo '  <div x-show="$parent.selectedKategoriSlug && $parent.selectedKategoriSlug.includes('"'"'arsa'"'"')">'
    echo ""
    exit 1
fi

echo -e "${GREEN}✓ Tüm Blade @include + Alpine.js scope kontrolleri başarılı${NC}"
exit 0
